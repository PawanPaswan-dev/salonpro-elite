# SalonPro Elite - Environment Variables (Demo)
# This demo build runs entirely on in-memory generated data and
# does not require a database or external services.
# The variables below are placeholders for the production version
# described in PROJECT_GUIDE.md (Next.js + Prisma + NextAuth).

# Database (Postgres - e.g. Neon, Supabase, Vercel Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/salonpro"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_NAME="SalonPro Elite"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
